<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.QuizApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.QuizApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/transparent</item>
        <item name="windowSplashScreenAnimatedIcon">@null</item>
        <item name="postSplashScreenTheme">@style/Theme.QuizApp</item>
    </style>
</resources>
